{
  "workflow_id": "recon_basic_collection_flow",
  "name": "recon_basic_collection_flow",
  "description": "Authorized basic collection workflow: scope validation, target normalization, DNS probe, HTTP liveness, low-rate port scan, URL inventory, port/service merge, attack-surface summary, next-step options, and report draft. Heavy service/web/vulnerability steps remain single-function AI-gated follow-ups.",
  "tags": [
    "recon_scan",
    "authorized",
    "active",
    "basic-collection",
    "ai-gated"
  ],
  "risk": "high",
  "network": true,
  "config_required": false,
  "default_safe": false,
  "workflow": {
    "name": "recon_basic_collection_flow",
    "steps": [
      {
        "function_id": "recon.scope_validate",
        "params": {
          "active_scan": true,
          "targets": [],
          "authorized_scope": [],
          "exclude": [],
          "confirm_authorized": ""
        },
        "step_id": "recon_basic_collection_flow_01_scope_validate"
      },
      {
        "function_id": "recon.target_normalize",
        "params": {},
        "step_id": "recon_basic_collection_flow_02_target_normalize",
        "depends_on": [
          "recon_basic_collection_flow_01_scope_validate"
        ]
      },
      {
        "function_id": "recon.dns_probe",
        "params": {
          "rate_limit": "low",
          "timeout_seconds": 90
        },
        "step_id": "recon_basic_collection_flow_03_dns_probe",
        "depends_on": [
          "recon_basic_collection_flow_02_target_normalize"
        ]
      },
      {
        "function_id": "recon.http_probe",
        "params": {
          "rate_limit": "low",
          "timeout_seconds": 120
        },
        "step_id": "recon_basic_collection_flow_04_http_probe",
        "depends_on": [
          "recon_basic_collection_flow_03_dns_probe"
        ]
      },
      {
        "function_id": "recon.port_scan",
        "params": {
          "ports": "top-1000",
          "rate_limit": "low",
          "timeout_seconds": 180
        },
        "step_id": "recon_basic_collection_flow_05_port_scan",
        "depends_on": [
          "recon_basic_collection_flow_04_http_probe"
        ]
      },
      {
        "function_id": "recon.url_inventory",
        "params": {},
        "step_id": "recon_basic_collection_flow_06_url_inventory",
        "depends_on": [
          "recon_basic_collection_flow_05_port_scan"
        ]
      },
      {
        "function_id": "recon.port_service_merge",
        "params": {},
        "step_id": "recon_basic_collection_flow_07_port_service_merge",
        "depends_on": [
          "recon_basic_collection_flow_06_url_inventory"
        ]
      },
      {
        "function_id": "recon.attack_surface_summarize",
        "params": {},
        "step_id": "recon_basic_collection_flow_08_attack_surface_summarize",
        "depends_on": [
          "recon_basic_collection_flow_07_port_service_merge"
        ]
      },
      {
        "function_id": "recon.next_step_options",
        "params": {},
        "step_id": "recon_basic_collection_flow_09_next_step_options",
        "depends_on": [
          "recon_basic_collection_flow_08_attack_surface_summarize"
        ]
      },
      {
        "function_id": "recon.report_generate",
        "params": {
          "report_stage": "basic_collection"
        },
        "step_id": "recon_basic_collection_flow_10_report_generate",
        "depends_on": [
          "recon_basic_collection_flow_09_next_step_options"
        ]
      }
    ]
  }
}
