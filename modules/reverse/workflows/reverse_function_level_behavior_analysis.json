{
  "workflow_id": "reverse_function_level_behavior_analysis",
  "name": "reverse_function_level_behavior_analysis",
  "description": "High-risk single-sample workflow that automatically downloads one MalwareBazaar sample, runs static analysis, runs broad VMware dynamic analysis, runs function-level analysis, then performs focused dynamic and focused function-level checks for behavior gaps.",
  "tags": [
    "reverse",
    "single-sample",
    "malwarebazaar",
    "static",
    "dynamic",
    "function-level",
    "ida",
    "ghidra",
    "focused-validation"
  ],
  "risk": "high",
  "network": true,
  "config_required": true,
  "default_safe": false,
  "workflow": {
    "name": "reverse_function_level_behavior_analysis",
    "steps": [
      {
        "function_id": "ti.malwarebazaar.download_sample",
        "params": {
          "confirm_download": "I_UNDERSTAND_DOWNLOAD_MALWARE_SAMPLE",
          "query": "get_recent",
          "selector": "100",
          "allowed_file_types": [
            "exe"
          ],
          "exclude_keywords": [
            "wannacry",
            "ransom",
            "ransomware",
            "worm"
          ],
          "max_download_bytes": 8388608
        },
        "step_id": "reverse_function_level_behavior_analysis_01_download_sample"
      },
      {
        "function_id": "hash.compute",
        "params": {},
        "step_id": "reverse_function_level_behavior_analysis_02_compute",
        "depends_on": [
          "reverse_function_level_behavior_analysis_01_download_sample"
        ]
      },
      {
        "function_id": "file.type_detect",
        "params": {},
        "step_id": "reverse_function_level_behavior_analysis_03_type_detect",
        "depends_on": [
          "reverse_function_level_behavior_analysis_02_compute"
        ]
      },
      {
        "function_id": "file.multi_format_parse",
        "params": {},
        "step_id": "reverse_function_level_behavior_analysis_04_multi_format_parse",
        "depends_on": [
          "reverse_function_level_behavior_analysis_03_type_detect"
        ]
      },
      {
        "function_id": "file.byte_stats",
        "params": {},
