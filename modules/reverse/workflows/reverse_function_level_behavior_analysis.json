        "depends_on": [
          "reverse_function_level_behavior_analysis_05_byte_stats"
        ]
      },
      {
        "function_id": "strings.extract",
        "params": {
          "min_length": 4,
          "max_strings": 5000
        },
        "step_id": "reverse_function_level_behavior_analysis_07_extract",
        "depends_on": [
          "reverse_function_level_behavior_analysis_06_deep_parse"
