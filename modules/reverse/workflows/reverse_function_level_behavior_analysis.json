{
  "workflow_id": "reverse_function_level_behavior_analysis",
  "name": "reverse_function_level_behavior_analysis",
  "description": "High-risk single-sample workflow that automatically downloads one MalwareBazaar sample, runs static analysis, runs broad VMware dynamic analysis, runs function-level analysis, then performs focused dynamic and focused function-level checks for behavior gaps.",
  "tags": ["reverse", "single-sample", "malwarebazaar", "static", "dynamic", "function-level", "ida", "ghidra", "focused-validation"],
  "risk": "high",
  "network": true,
  "config_required": true,
  "default_safe": false,
  "workflow": {
    "name": "reverse_function_level_behavior_analysis",
    "steps": [
      {
        "function_id": "ti.malwarebazaar.download_sample",
        "params": {
          "confirm_download": "I_UNDERSTAND_DOWNLOAD_MALWARE_SAMPLE",
          "query": "get_recent",
          "selector": "100",
          "allowed_file_types": ["exe"],
          "exclude_keywords": ["wannacry", "ransom", "ransomware", "worm"],
          "max_download_bytes": 8388608
        }
      },
      {"function_id": "hash.compute", "params": {}},
      {"function_id": "file.type_detect", "params": {}},
      {"function_id": "file.multi_format_parse", "params": {}},
      {"function_id": "file.byte_stats", "params": {}},
      {"function_id": "pe.deep_parse", "params": {}},
      {"function_id": "strings.extract", "params": {"min_length": 4, "max_strings": 5000}},
      {"function_id": "strings.enhanced_extract", "params": {"min_length": 4, "max_strings": 5000}},
      {"function_id": "ioc.extract", "params": {}},
      {"function_id": "packer.detect_enhanced", "params": {}},
      {
        "function_id": "dynamic.vm_preflight",
        "params": {
          "require_guest_credentials": true
        }
      },
      {"function_id": "dynamic.vm_status", "params": {}},
      {
        "function_id": "dynamic.vm_restore_snapshot",
        "params": {
          "confirm_restore": "I_UNDERSTAND_RESTORE_VM_SNAPSHOT",
          "stop_if_running": true
        }
      },
      {"function_id": "dynamic.vm_upload_sample", "params": {}},
      {
        "function_id": "dynamic.vm_run_sample",
        "params": {
          "confirm_execute": "I_UNDERSTAND_RUN_SAMPLE_IN_VM",
          "duration_seconds": 60
        }
      },
      {"function_id": "dynamic.vm_collect_sysmon", "params": {"last_minutes": 60}},
      {"function_id": "dynamic.vm_save_snapshot", "params": {}},
      {
        "function_id": "dynamic.vm_restore_snapshot",
        "params": {
          "confirm_restore": "I_UNDERSTAND_RESTORE_VM_SNAPSHOT",
          "stop_if_running": true
        }
      },
      {"function_id": "behavior.map_dynamic", "params": {}},
      {"function_id": "tool.ida_function_analyze", "params": {}},
      {"function_id": "tool.ida_function_features", "params": {"max_functions": 800}},
      {"function_id": "tool.ghidra_function_analyze", "params": {}},
      {"function_id": "tool.ghidra_function_features", "params": {"max_functions": 800}},
      {"function_id": "tool.binaryninja_function_analyze", "params": {}},
      {"function_id": "behavior.map_static", "params": {}},
      {"function_id": "attack.map_static", "params": {}},
      {"function_id": "validation.compare_static_dynamic", "params": {}},
      {"function_id": "validation.compare_static_dynamic_function", "params": {}},
      {"function_id": "validation.plan_focused_dynamic", "params": {}},
      {"function_id": "validation.plan_focused_function_level", "params": {}},
      {
        "function_id": "dynamic.vm_validate_behavior",
        "params": {
          "confirm_execute": "I_UNDERSTAND_RUN_FOCUSED_BEHAVIOR_VALIDATION_IN_VM",
          "confirm_restore": "I_UNDERSTAND_RESTORE_VM_SNAPSHOT",
          "restore_before": true,
          "restore_after": true,
          "save_snapshot_after": true,
          "duration_seconds": 30,
          "last_minutes": 30
        }
      },
      {"function_id": "tool.focused_function_level_analysis", "params": {"max_matches_per_target": 20}}
    ]
  }
}
