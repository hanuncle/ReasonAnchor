          "reverse_auto_download_static_dynamic_focused_11_map_static"
        ]
      },
      {
        "function_id": "ti.malwarebazaar.hash_lookup",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_13_hash_lookup",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_12_map_static"
        ]
      },
      {
        "function_id": "ti.virustotal.hash_lookup",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_14_hash_lookup",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_13_hash_lookup"
        ]
      },
      {
        "function_id": "ti.virustotal.behaviour_summary",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_15_behaviour_summary",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_14_hash_lookup"
        ]
      },
      {
        "function_id": "dynamic.vm_preflight",
        "params": {
          "require_guest_credentials": true
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_16_vm_preflight",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_15_behaviour_summary"
