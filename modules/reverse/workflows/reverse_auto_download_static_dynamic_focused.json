      },
      {
        "function_id": "dynamic.vm_restore_snapshot",
        "params": {
          "confirm_restore": "I_UNDERSTAND_RESTORE_VM_SNAPSHOT",
          "stop_if_running": true
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_23_vm_restore_snapshot",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_22_vm_save_snapshot"
        ]
      },
      {
        "function_id": "behavior.map_dynamic",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_24_map_dynamic",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_23_vm_restore_snapshot"
        ]
      },
      {
        "function_id": "validation.compare_static_dynamic",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_25_compare_static_dynamic",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_24_map_dynamic"
        ]
      },
      {
        "function_id": "validation.plan_focused_dynamic",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_26_plan_focused_dynamic",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_25_compare_static_dynamic"
        ]
      },
      {
        "function_id": "dynamic.vm_validate_behavior",
        "params": {
          "confirm_execute": "I_UNDERSTAND_RUN_FOCUSED_BEHAVIOR_VALIDATION_IN_VM",
          "confirm_restore": "I_UNDERSTAND_RESTORE_VM_SNAPSHOT",
          "restore_before": true,
          "restore_after": true,
          "save_snapshot_after": true,
          "duration_seconds": 30,
          "last_minutes": 30
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_27_vm_validate_behavior",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_26_plan_focused_dynamic"
        ]
      }
    ]
  }
}
