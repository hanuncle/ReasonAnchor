        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_16_vm_preflight"
        ]
      },
      {
        "function_id": "dynamic.vm_restore_snapshot",
        "params": {
          "confirm_restore": "I_UNDERSTAND_RESTORE_VM_SNAPSHOT",
          "stop_if_running": true
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_18_vm_restore_snapshot",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_17_vm_status"
        ]
      },
      {
        "function_id": "dynamic.vm_upload_sample",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_19_vm_upload_sample",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_18_vm_restore_snapshot"
        ]
      },
      {
        "function_id": "dynamic.vm_run_sample",
        "params": {
          "confirm_execute": "I_UNDERSTAND_RUN_SAMPLE_IN_VM",
          "duration_seconds": 60
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_20_vm_run_sample",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_19_vm_upload_sample"
        ]
      },
      {
        "function_id": "dynamic.vm_collect_sysmon",
        "params": {
          "last_minutes": 60
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_21_vm_collect_sysmon",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_20_vm_run_sample"
        ]
      },
      {
        "function_id": "dynamic.vm_save_snapshot",
        "params": {},
