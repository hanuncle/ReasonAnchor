{
  "workflow_id": "reverse_auto_download_static_dynamic_focused",
  "name": "reverse_auto_download_static_dynamic_focused",
  "description": "High-risk workflow that downloads one MalwareBazaar sample into quarantine, runs static analysis, runs broad VMware dynamic analysis, compares static and dynamic behaviors, then runs one focused dynamic validation target for behavior that was not observed dynamically.",
  "tags": [
    "reverse",
    "malwarebazaar",
    "static",
    "dynamic",
    "vmware",
    "focused-validation"
  ],
  "risk": "high",
  "network": true,
  "config_required": true,
  "default_safe": false,
  "workflow": {
    "name": "reverse_auto_download_static_dynamic_focused",
    "steps": [
      {
        "function_id": "ti.malwarebazaar.download_sample",
        "params": {
          "confirm_download": "I_UNDERSTAND_DOWNLOAD_MALWARE_SAMPLE",
          "query": "get_recent",
          "selector": "100",
          "allowed_file_types": [
            "exe"
          ],
          "exclude_keywords": [
            "wannacry",
            "ransom",
            "ransomware",
            "worm"
          ],
          "max_download_bytes": 8388608
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_01_download_sample"
      },
      {
        "function_id": "hash.compute",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_02_compute",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_01_download_sample"
        ]
      },
      {
        "function_id": "file.type_detect",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_03_type_detect",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_02_compute"
        ]
      },
      {
        "function_id": "file.multi_format_parse",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_04_multi_format_parse",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_03_type_detect"
        ]
      },
      {
        "function_id": "file.byte_stats",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_05_byte_stats",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_04_multi_format_parse"
        ]
      },
      {
        "function_id": "pe.deep_parse",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_06_deep_parse",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_05_byte_stats"
        ]
      },
      {
        "function_id": "strings.extract",
        "params": {
          "min_length": 4,
          "max_strings": 5000
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_07_extract",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_06_deep_parse"
        ]
      },
      {
        "function_id": "strings.enhanced_extract",
        "params": {
          "min_length": 4,
          "max_strings": 5000
        },
        "step_id": "reverse_auto_download_static_dynamic_focused_08_enhanced_extract",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_07_extract"
        ]
      },
      {
        "function_id": "ioc.extract",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_09_extract",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_08_enhanced_extract"
        ]
      },
      {
        "function_id": "packer.detect_enhanced",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_10_detect_enhanced",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_09_extract"
        ]
      },
      {
        "function_id": "behavior.map_static",
        "params": {},
        "step_id": "reverse_auto_download_static_dynamic_focused_11_map_static",
        "depends_on": [
          "reverse_auto_download_static_dynamic_focused_10_detect_enhanced"
        ]
      },
      {
        "function_id": "attack.map_static",
        "params": {},
