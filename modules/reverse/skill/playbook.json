    "behavior_mapping_function": "modules/reverse/functions/behavior_map_static.py",
    "attack_mapping_function": "modules/reverse/functions/attack_map_static.py",
    "behavior_taxonomy": "modules/reverse/knowledge/behavior_taxonomy.json",
    "attack_knowledge": "modules/reverse/knowledge/attack/techniques.json",
