    "raw_sorting_functions": "modules/reverse/config_files/raw_sorting/",
    "module_feature_functions": "modules/reverse/functions/"
  },
  "self_iteration_rules": [
    {
      "condition": "behavior.map_static misses, over-maps, or has weak evidence",
      "action": "update behavior_taxonomy first, then improve behavior_mapping_function or add upstream module_feature_functions when code changes are required"
    },
    {
      "condition": "attack.map_static misses ATT&CK mappings",
      "action": "update attack_knowledge before changing attack_mapping_function"
    },
    {
      "condition": "a behavior needs dynamic validation but no scenario exists",
      "action": "add validation_scenarios entry and connect it to attack_knowledge"
    },
    {
      "condition": "static behavior is not observed in broad dynamic telemetry",
      "action": "run dynamic.vm_preflight first; if ready, run validation.plan_focused_dynamic, then use dynamic.vm_validate_behavior for the selected behavior"
    },
    {
      "condition": "a technique needs a benign single-point validation fixture",
      "action": "add validation_samples file and register it in validation_samples_manifest"
    },
    {
      "condition": "behavior or ATT&CK mapping output is noisy",
      "action": "improve raw_sorting_functions before querying full raw_output repeatedly"
    },
    {
      "condition": "analysis reveals a reusable lesson but official knowledge should not be changed during the run",
      "action": "call knowledge.update_candidate to store a pending review candidate under knowledge_update_candidates"
    }
  ]
}
