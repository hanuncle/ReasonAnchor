  "ui": {
    "pages": [
      {
        "page_id": "attack_knowledge",
        "title": "ATT&CK Knowledge",
        "description": "ATT&CK techniques mapped to reverse-module behavior categories, analysis methods, detection methods, and validation assets.",
        "type": "knowledge_table",
        "knowledge_type": "attack_techniques",
        "columns": [
          "technique_id",
          "name",
          "tactic",
          "behavior_categories",
          "analysis_methods",
          "detection_methods",
          "validation_samples"
        ]
      },
      {
        "page_id": "behavior_taxonomy",
        "title": "Behavior Taxonomy",
        "description": "Canonical behavior categories used by static mapping, dynamic mapping, ATT&CK mapping, validation, and sample-set reports.",
        "type": "taxonomy_browser",
        "knowledge_type": "behavior_taxonomy",
        "columns": [
          "id",
          "name",
          "description",
          "attack_techniques"
        ]
      },
      {
        "page_id": "validation_samples",
        "title": "Validation Samples",
        "description": "Benign single-point validation fixtures for checking behavior mapping and VM telemetry consistency.",
        "type": "knowledge_table",
        "knowledge_type": "validation_samples",
        "columns": [
          "sample_id",
          "name",
          "behavior_category",
          "technique_id",
          "expected_dynamic_events",
          "cleanup"
        ]
      }
    ]
